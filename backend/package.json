{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "rimraf dist && tsc",
        "start": "node .",
        "migrate:up": "node-pg-migrate up --database-url-var POSTGRES_URL -m migrations",
        "migrate:down": "node-pg-migrate down --database-url-var POSTGRES_URL -m migrations",
        "migrate:create": "node-pg-migrate create --migration-file-language sql -m migrations",
        "generate:openapi": "curl -sf http://localhost:3000/docs/json -o openapi.json",
        "format:write": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/pg": "^8.15.6",
        "prettier": "^3.6.2",
        "rimraf": "^6.1.2",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.6",
        "bcrypt": "^6.0.0",
        "fastify": "^5.8.5",
        "fastify-zod-openapi": "^5.6.1",
        "node-pg-migrate": "^8.0.4",
        "pg": "^8.16.3",
        "pino": "^10.1.0",
        "pino-loki": "^2.6.0",
        "pino-pretty": "^13.1.2",
        "zod": "^4.4.3",
        "zod-openapi": "^5.4.6"
    }
}
